<style>
    /* --------------------------------------------------------------------- */
    /* A5 Landscape Layout (210mm x 148mm) - Tuned Typography and Spacing    */
    /* --------------------------------------------------------------------- */
    :root {
        /* Physical page size */
        --page-w: 210mm;
        --page-h: 148mm;
        /* Baseline sizes tuned for A5 landscape */
        --font-base: 10pt;
        --font-sm: 8pt;
        --font-xs: 7.5pt;
        --font-lg: 12pt;
        --space-xxs: 2pt;
        --space-xs: 4pt;
        --space-sm: 6pt;
        --space-md: 8pt;
        --space-lg: 10pt;
        --border: 1px dashed #999;
        --border-strong: 1px dashed #333;
    }

    .report-content {
        width: var(--page-w);
        height: var(--page-h);
        margin: 0 auto;
        padding: 8mm;
        background: white;
        font-size: var(--font-base);
        font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji";
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    /* Header */
    header {
        text-align: center;
        padding-bottom: var(--space-xs);
        border-bottom: var(--border-strong);
    }

    header h1 {
        font-size: var(--font-lg);
        font-weight: 800;
        margin: 0 0 var(--space-xxs);
        letter-spacing: 0.2px;
    }

    header p,
    header .tin {
        font-size: var(--font-xs);
        margin: 0;
        line-height: 1.2;
    }

    header h2 {
        margin: var(--space-xs) 0 0;
        font-size: 11pt;
        font-weight: 700;
    }

    /* Details Grid */
    .loan-grid {
        display: grid;
        grid-template-columns: 1fr 1fr; /* Use width of A5 landscape */
        gap: var(--space-xs) var(--space-sm);
        font-size: 9pt;
    }

    .loan-grid p {
        margin: 0;
    }

    /* Table */
    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 9pt;
        text-align: left;
    }

    thead th {
        text-transform: uppercase;
        background: none;
        font-size: var(--font-xs);
        padding: 3pt 0;
        font-weight: 700;
        border-bottom: var(--border);
        letter-spacing: 0.3px;
    }

    tbody td {
        padding: 3pt 0;
        vertical-align: top;
    }

    tbody tr + tr {
        border-top: 0.5px dashed #ddd;
    }

    tfoot td,
    .totals {
        font-size: 10pt;
        font-weight: 700;
        border-top: var(--border-strong);
        padding-top: 4pt;
    }

    /* Amount in Words */
    .amount-words {
        margin-top: var(--space-sm);
        padding: var(--space-xs) 0;
        border-top: var(--border-strong);
        border-bottom: var(--border-strong);
        font-size: 9.5pt;
        font-weight: 600;
        text-align: center;
        letter-spacing: 0.3px;
    }

    /* Signatures */
    .signature-grid {
        margin-top: var(--space-sm);
        display: grid;
        grid-template-columns: 1fr 1fr; /* Two columns fit A5 landscape */
        gap: var(--space-md);
        font-size: 9pt;
    }

    .signature-grid > div {
        display: flex;
        flex-direction: column;
        gap: var(--space-xxs);
    }

    .signature-line {
        border-bottom: var(--border);
        min-height: 1rem;
    }

    /* Approval */
    .approval-section {
        margin-top: var(--space-sm);
        text-align: center;
    }

    .approval-section p {
        font-size: 10pt;
        margin: 0;
    }

    .approval-line {
        width: 70%;
        margin: var(--space-xxs) auto 0;
        border-bottom: var(--border);
        min-height: 1rem;
    }

    /* Print Setup */

</style>

<div class="report-content">
   <header>
      <h1>{{header_title}}</h1>
      <p class="">{{header_address}}</p>
      <p class="tin">TIN: {{tax_number}}</p>
      <h2>{{report_title}}</h2>
   </header>
   <div class="loan-grid">
      <div>
         <p class="title">Pay To:{{pay_to}}</p>
         <p class="subtext">Account No: {{account_number}}</p>
         <p class="subtext">Contact: {{contact}}</p>
      </div>
      <div>
         <p><span class="title">Voucher No:</span> {{voucher_no}}</p>
         <p><span class="title">Release Date:</span> {{date_release}}</p>
         <p><span class="title">Terms:</span> {{terms}} months ({{mode_of_payment}})</p>
      </div>
      <div>
         <p><span class="title">Processor:</span> {{processor}}</p>
         <p><span class="title">Due Date:</span> <span style="color:#dc2626; font-weight:600">{{due_date}}</span></p>
      </div>
   </div>
   <div class=" shadow-md rounded-lg">
      <table>
         <thead>
            <tr>
               <th>ACCOUNT TITLE</th>
               <th class="text-right">DEBIT (PHP)</th>
               <th class="text-right">CREDIT (PHP)</th>
            </tr>
         </thead>
         <tbody>
            {{#each loan_transaction_entries}}
            <tr class="{{#if is_highlighted}}highlight{{/if}}">
               <td>{{account_title}}</td>
               <td class="text-right">{{debit}}</td>
               <td class="text-right">{{credit}}</td>
            </tr>
            {{/each}}
            <tr class="totals">
               <td colspan="1">TOTAL:</td>
               <td class="text-right">{{cash_on_hand_total_debit}}</td>
               <td class="text-right">{{cash_on_hand_total_credit}}</td>
            </tr>
         </tbody>
      </table>
   </div>
   <div class="amount-words">
      *** {{total_amount_in_words}} ONLY ***
   </div>
   <div class="signature-grid">
      <div>
         <p class="label">Prepared by:</p>
         <p class="signature-line">{{prepared_by}}</p>
      </div>
      <div>
         <p class="label">Payee:</p>
         <p class="signature-line">{{payeee}}</p>
      </div>
      <div>
         <p class="label">Certified Correct:</p>
         <p class="signature-line">{{cetified_correct}}</p>
      </div>
      <div>
         <p class="label">Paid by:</p>
         <p class="signature-line">{{paid_by}}</p>
      </div>
   </div>
   <div class="approval-section">
      <p>Approved for Payment:</p>
      <div class="approval-line">{{approved_for_payment}}</div>
   </div>
</div>