<style>
    /* --------------------------------------------------------------------- */
    /* Base Styles (Borderless, Minimalist Look)                             */
    /* --------------------------------------------------------------------- */
    .report-content {
        width: 100%;
        min-height: 100vh;
        padding: 2%;
        background: white;
        font-size: 0.875rem;
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        box-sizing: border-box;
    }

    /* Header */
    header {
        text-align: center;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        /* Line Removed */
    }

    /* Grid layout */
    .loan-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem 2rem;
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
    }

    /* Table */
    table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        font-size: 0.875rem;
        color: #6b7280;
        text-align: left;
    }

    table th {
        text-transform: uppercase;
        background: none; /* Background Removed */
        font-size: 0.75rem;
        color: #374151;
        padding: 0.75rem 1rem;
        font-weight: 700;
    }

    table td {
        padding: 0.75rem 1rem;
    }

    table tbody tr {
        /* Line Removed */
    }

    .highlight {
        background: none; /* Background Removed */
        color: #111827;
        font-weight: 700;
        /* Borders Removed */
    }

    .totals {
        background: none; /* Background Removed */
        font-size: 1rem;
        color: #1f2937;
        font-weight: 700;
        /* Add a light line below totals for definition */
        border-top: 1px solid #ccc;
    }

    .amount-words {
        margin-top: 1rem;
        padding: 1rem;
        background: none; /* Background Removed */
        border: none; /* Border Removed */
        color: #92400e;
        font-size: 0.875rem;
        font-weight: 600;
        text-align: center;
    }
    /* ... (rest of the styles and print media queries omitted for brevity) ... */

    /* The HTML structure remains identical for all samples below */
</style>

<div class="report-content">
   <header>
      <h1>{{header_title}}</h1>
      <p class="">{{header_address}}</p>
      <p class="tin">TIN: {{tax_number}}</p>
      <h2>{{report_title}}</h2>
   </header>
   <div class="loan-grid">
      <div>
         <p class="title">Pay To:{{pay_to}}</p>
         <p class="subtext">Account No: {{account_number}}</p>
         <p class="subtext">Contact: {{contact}}</p>
      </div>
      <div>
         <p><span class="title">Voucher No:</span> {{voucher_no}}</p>
         <p><span class="title">Release Date:</span> {{date_release}}</p>
         <p><span class="title">Terms:</span> {{terms}} months ({{mode_of_payment}})</p>
      </div>
      <div>
         <p><span class="title">Processor:</span> {{processor}}</p>
         <p><span class="title">Due Date:</span> <span style="color:#dc2626; font-weight:600">{{due_date}}</span></p>
      </div>
   </div>
   <div class="overflow-x-auto shadow-md rounded-lg">
      <table>
         <thead>
            <tr>
               <th>ACCOUNT TITLE</th>
               <th class="text-right">DEBIT (PHP)</th>
               <th class="text-right">CREDIT (PHP)</th>
            </tr>
         </thead>
         <tbody>
            {{#each loan_transaction_entries}}
            <tr class="{{#if is_highlighted}}highlight{{/if}}">
               <td>{{account_title}}</td>
               <td class="text-right">{{debit}}</td>
               <td class="text-right">{{credit}}</td>
            </tr>
            {{/each}}
            <tr class="totals">
               <td colspan="1">TOTAL:</td>
               <td class="text-right">{{cash_on_hand_total_debit}}</td>
               <td class="text-right">{{cash_on_hand_total_credit}}</td>
            </tr>
         </tbody>
      </table>
   </div>
   <div class="amount-words">
      *** {{total_amount_in_words}} ONLY ***
   </div>
   <div class="signature-grid">
      <div>
         <p class="label">Prepared by:</p>
         <p class="signature-line">{{prepared_by}}</p>
      </div>
      <div>
         <p class="label">Payee:</p>
         <p class="signature-line">{{payeee}}</p>
      </div>
      <div>
         <p class="label">Certified Correct:</p>
         <p class="signature-line">{{cetified_correct}}</p>
      </div>
      <div>
         <p class="label">Paid by:</p>
         <p class="signature-line">{{paid_by}}</p>
      </div>
   </div>
   <div class="approval-section">
      <p>Approved for Payment:</p>
      <div class="approval-line">{{approved_for_payment}}</div>
   </div>
</div>