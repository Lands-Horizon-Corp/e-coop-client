<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Other Fund Voucher</title>
        <style>
            @page {
                margin: 0;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body,
            html {
                margin: 0;
                padding: 0;
                min-height: 100%;
                background-color: #f9fafb;
            }

            body {
                display: flex;
                flex-direction: column;
            }

            .container {
                --fs-xs: 7px;
                --fs-sm: 8px;
                --fs-base: 9px;
                --fs-lg: 10px;
                --fs-xl: 12px;
                --fs-2xl: 14px;

                padding: 0.3in;
                background: white;
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
                color: #1f2937;
                font-size: var(--fs-base);
                line-height: 1.3;
                flex-grow: 1;
                display: flex;
                flex-direction: column;
                width: 100%;
            }

            /* Header Section */
            .header {
                text-align: center;
                margin-bottom: 0.3rem;
                padding-bottom: 0.15rem;
                border-bottom: 1px solid #e5e7eb;
            }

            .header h1 {
                font-size: var(--fs-xl);
                font-weight: 800;
                color: #111827;
                margin-bottom: 0.1rem;
                letter-spacing: -0.025em;
            }

            .header .address {
                font-size: var(--fs-base);
                color: #6b7280;
                margin: 0.1rem 0;
            }

            .header .tin {
                font-size: var(--fs-sm);
                color: #575656;
            }

            .report-title {
                font-size: var(--fs-2xl);
                font-weight: 800;
                color: #111827;
                margin-top: 0.25rem;
                letter-spacing: -0.025em;
                text-transform: uppercase;
            }

            /* Info Grid */
            .info-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 0.15rem;
                margin-bottom: 0.4rem;
                font-size: var(--fs-base);
            }

            .info-item {
                padding: 0.08rem;
            }

            .info-label {
                font-size: var(--fs-sm);
                font-weight: 600;
                color: #575656;
                display: inline-block;
                min-width: 65px;
            }

            .info-value {
                font-size: var(--fs-base);
                color: #1f2937;
                font-weight: 600;
                padding-left: 0.25rem;
            }

            /* Table Section */
            .table-wrapper {
                width: 100%;
                margin-bottom: 0.3rem;
            }

            .table-wrapper table {
                width: 100%;
                border-collapse: collapse;
                background: white;
                font-size: var(--fs-base);
            }

            .table-wrapper th {
                text-transform: uppercase;
                font-size: var(--fs-sm);
                font-weight: 700;
                color: #374151;
                padding: 0.3rem;
                text-align: left;
                border-bottom: 2px solid #e5e7eb;
            }

            .table-wrapper td {
                padding: 0.25rem 0.3rem;
                border-bottom: 1px solid #f3f4f6;
            }

            .text-right {
                text-align: right;
                font-family: 'SF Mono', 'Monaco', 'Courier New', monospace;
                font-variant-numeric: tabular-nums;
            }

            .highlight {
                background: #dbeafe !important;
                font-weight: 700;
                color: #1e40af;
                border-top: 1px solid #3b82f6;
                border-bottom: 1px solid #3b82f6;
            }

            .totals {
                background: #f3f4f6;
                font-weight: 700;
                color: #111827;
                font-size: var(--fs-base);
                border-top: 1px solid #9ca3af;
            }

            /* Check Details & Reprint Section */
            .payment-details {
                margin: 0.3rem 0;
                padding: 0.3rem;
                border-top: 1px solid #e5e7eb;
                font-size: var(--fs-base);
            }

            .reprint-indicator {
                margin: 0.4rem 0;
                padding: 0.25rem;
                color: #ef4444;
                font-size: var(--fs-base);
                font-weight: 800;
                text-align: center;
                letter-spacing: 0.05em;
            }

            /* Signature Section */
            .signature-section {
                margin-top: 1rem;
                padding-top: 0.5rem;
            }

            .signature-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 1.5rem 2.5rem;
                padding: 0 5%;
            }

            .signature-item {
                text-align: center;
            }

            .signature-label {
                font-size: var(--fs-sm);
                font-weight: 700;
                color: #6b7280;
                margin-bottom: 0.15rem;
                text-transform: uppercase;
            }

            .signature-line {
                border-bottom: 1px solid #9ca3af;
                padding: 0.15rem 0;
                min-height: 1.2rem;
                font-weight: 600;
                font-size: var(--fs-base);
                color: #1f2937;
                margin-top: 0.15rem;
            }

            /* Footer */
            .footer {
                margin-top: auto;
                display: flex;
                justify-content: space-between;
                font-size: var(--fs-xs);
                color: #9ca3af;
                border-top: 1px dotted #e5e7eb;
                padding-top: 5px;
            }

            @media print {
                body {
                    background-color: white;
                }
                * {
                    -webkit-print-color-adjust: exact;
                    print-color-adjust: exact;
                }
            }
        </style>
    </head>
    <body>
        <div class="container">
            <header class="header">
                <h1>{{ header_title }}</h1>
                <p class="address">{{ header_address }}</p>
                <p class="tin">TIN: {{ tax_number }}</p>
                <h1 class="report-title">{{ report_title }}</h1>
            </header>

            <div class="info-grid">
                <div class="info-item">
                    <p>
                        <span class="info-label">Name:</span><span class="info-value">{{ member_name }}</span></p>
                    {% if member_address %}
                        <p>
                            <span class="info-label">Address:</span><span class="info-value" style="font-weight: 400;">{{ member_address }}</span></p>
                    {% endif %}
                    <p>
                        <span class="info-label" style="font-size: var(--fs-xs);">Particulars:</span><span class="info-value" style="font-weight: 400;">{{ particulars }}</span></p>
                </div>
                <div class="info-item" style="text-align: right;">
                    <p>
                        <span class="info-label">Voucher No:</span><span class="info-value">{{ voucher_no }}</span></p>
                    <p>
                        <span class="info-label">Entry Date:</span><span class="info-value">{{ entry_date }}</span></p>
                </div>
            </div>

            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Account Title / Description</th>
                            <th class="text-right">Debit (₱)</th>
                            <th class="text-right">Credit (₱)</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for entry in other_fund_entries %}
                            <tr class="{% if entry.is_highlighted %}highlight{% endif %}">
                                <td>
                                    <div style="font-weight: 600;">{{ entry.account_title }}</div>
                                    <div style="font-size: var(--fs-xs); color: #6b7280;">{{ entry.description }}</div>
                                </td>
                                <td class="text-right">{{ entry.debit }}</td>
                                <td class="text-right">{{ entry.credit }}</td>
                            </tr>
                        {% endfor %}
                        <tr class="totals">
                            <td>TOTAL</td>
                            <td class="text-right">{{ total_debit }}</td>
                            <td class="text-right">{{ total_credit }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="payment-details">
                {% if check_number %}
                    <span class="info-label">Check No:</span>
                    <span class="info-value">{{ check_number }}</span>
                {% endif %}
                {% if check_date %}
                    <span class="info-label" style="margin-left: 20px;">Check Date:</span>
                    <span class="info-value">{{ check_date }}</span>
                {% endif %}
            </div>

            {% if print_count > 1 %}
                <div class="reprint-indicator">*** REPRINTED ({{ print_count }}) ***</div>
            {% endif %}

            <div class="signature-section">
                <div class="signature-grid">
                    <div class="signature-item">
                        <p class="signature-label">Certified By</p>
                        <div class="signature-line">{{ certified_by }}</div>
                    </div>
                    <div class="signature-item">
                        <p class="signature-label">Approved By</p>
                        <div class="signature-line">{{ approved_by }}</div>
                    </div>
                    <div class="signature-item">
                        <p class="signature-label">Paid By</p>
                        <div class="signature-line">{{ paid_by }}</div>
                    </div>
                    <div class="signature-item">
                        <p class="signature-label">Received By</p>
                        <div class="signature-line">{{ received_by }}</div>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>
