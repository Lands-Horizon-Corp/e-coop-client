<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Loan Release Voucher</title>
        <style>
            @page {
                margin: 0;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body,
            html {
                margin: 0;
                padding: 0;
                min-height: 100%;
                background-color: #f9fafb;
            }

            body {
                display: flex;
                flex-direction: column;
            }

            /* BASE VARS AT TOKEN */
            .container {
                /* FONT SCALE */
                --fs-xs: 7px;
                --fs-sm: 8px;
                --fs-base: 9px;
                --fs-lg: 10px;
                --fs-xl: 12px;
                --fs-2xl: 14px;

                /* SPACING SCALE */
                --space-xs: 0.08rem;
                --space-sm: 0.15rem;
                --space-md: 0.25rem;
                --space-lg: 0.3rem;
                --space-xl: 0.4rem;

                /* LAYOUT */
                --container-padding: 0.3in;
                --line-height: 1.3;

                --sig-gap-x: 0.7rem;
                --sig-gap-y: 1.4rem;
                --sig-margin-t: 2rem;

                padding: var(--container-padding);
                background: white;
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
                color: #1f2937;
                font-size: var(--fs-base);
                line-height: var(--line-height);
                flex-grow: 1;
                display: flex;
                flex-direction: column;
                width: 100%;
            }

            /* OTHER VARIANTS */

            /* NORMAL (default, explicit if you want) */
            .variant-normal .container {
                --fs-xs: 7px;
                --fs-sm: 8px;
                --fs-base: 9px;
                --fs-lg: 10px;
                --fs-xl: 12px;
                --fs-2xl: 14px;

                --space-xs: 0.08rem;
                --space-sm: 0.15rem;
                --space-md: 0.25rem;
                --space-lg: 0.3rem;
                --space-xl: 0.4rem;

                --sig-gap-x: 0.7rem;
                --sig-gap-y: 1.4rem;
                --sig-margin-t: 2rem;

                --container-padding: 0.3in;
                --line-height: 1.3;
            }

            /* COMPACT */
            .variant-compact .container {
                --fs-xs: 6px;
                --fs-sm: 7px;
                --fs-base: 8px;
                --fs-lg: 9px;
                --fs-xl: 10px;
                --fs-2xl: 12px;

                --space-xs: 0.05rem;
                --space-sm: 0.1rem;
                --space-md: 0.15rem;
                --space-lg: 0.2rem;
                --space-xl: 0.25rem;

                --sig-gap-x: 0.3rem;
                --sig-gap-y: 1rem;
                --sig-margin-t: 1.4rem;

                --container-padding: 0.15in;
                --line-height: 1.2;
            }

            /* LARGER */
            .variant-large .container {
                --fs-xs: 8px;
                --fs-sm: 10px;
                --fs-base: 12px;
                --fs-lg: 14px;
                --fs-xl: 16px;
                --fs-2xl: 18px;

                --space-xs: 0.1rem;
                --space-sm: 0.2rem;
                --space-md: 0.3rem;
                --space-lg: 0.4rem;
                --space-xl: 0.5rem;

                --sig-gap-x: 1.8rem;
                --sig-gap-y: 2rem;
                --sig-margin-t: 1rem;

                --container-padding: 0.4in;
                --line-height: 1.4;
            }

            /* HEADER */
            .header {
                text-align: center;
                margin-bottom: var(--space-lg);
                padding-bottom: var(--space-sm);
                border-bottom: 1px solid #e5e7eb;
            }

            .header h1 {
                font-size: var(--fs-xl);
                font-weight: 800;
                color: #111827;
                margin-bottom: var(--space-xs);
                letter-spacing: -0.025em;
            }

            .header .address {
                font-size: var(--fs-base);
                color: #6b7280;
                margin: var(--space-xs) 0;
            }

            .header .tin {
                font-size: var(--fs-sm);
                color: #575656;
            }

            .report-title {
                font-size: var(--fs-2xl);
                font-weight: 800;
                color: #111827;
                margin-top: var(--space-sm);
                letter-spacing: -0.025em;
                text-transform: uppercase;
            }

            /* INFO GRID */
            .info-grid {
                display: grid;
                gap: var(--space-sm);
                margin-bottom: var(--space-xl);
                font-size: var(--fs-base);
            }

            .grid-2 {
                grid-template-columns: repeat(2, 1fr);
            }

            .grid-3 {
                grid-template-columns: repeat(3, 1fr);
            }

            .info-item {
                padding: var(--space-xs);
            }

            .info-label {
                font-size: var(--fs-sm);
                font-weight: 600;
                color: #575656;
                display: inline-block;
                min-width: 65px;
            }

            .info-value {
                font-size: var(--fs-base);
                color: #1f2937;
                font-weight: 600;
                padding-left: var(--space-md);
            }

            /* TABLE */
            .table-wrapper {
                width: 100%;
                margin-bottom: var(--space-lg);
                border: 1px solid #e5e7eb;
                border-radius: 6px;
                overflow: hidden;
            }

            .table-wrapper table {
                width: 100%;
                border-collapse: collapse;
                background: white;
                font-size: var(--fs-base);
            }

            .table-wrapper th {
                text-transform: uppercase;
                font-size: var(--fs-sm);
                font-weight: 700;
                color: #374151;
                padding: var(--space-lg);
                text-align: left;
                border-bottom: 2px solid #e5e7eb;
            }

            .table-wrapper td {
                padding: var(--space-md) var(--space-lg);
                border-bottom: 1px solid #f3f4f6;
            }

            .text-right {
                text-align: right;
                font-family: 'SF Mono', 'Monaco', 'Courier New', monospace;
                font-variant-numeric: tabular-nums;
            }

            .highlight {
                background: #dbeafe !important;
                font-weight: 700;
                color: #1e40af;
                border-top: 1px solid #3b82f6;
                border-bottom: 1px solid #3b82f6;
            }

            .totals {
                background: #f3f4f6;
                font-weight: 700;
                color: #111827;
                font-size: var(--fs-base);
                border-top: 1px solid #9ca3af;
            }

            /* AMOUNT WORDS */
            .amount-words {
                margin: var(--space-xl) 0;
                padding: var(--space-lg);
                background: linear-gradient(to right, #fef3c7, #fde68a);
                border: 1px solid #fbbf24;
                border-radius: 2px;
                color: #78350f;
                font-size: var(--fs-xs);
                font-weight: 700;
                text-align: center;
            }

            /* CHECK DETAILS */
            .check-details {
                display: flex;
                justify-content: space-around;
                margin-bottom: var(--space-xl);
                padding: var(--space-sm);
                border: 1px dashed #d1d5db;
                font-size: var(--fs-xs);
            }

            /* REPRINT INDICATOR */
            .reprint-indicator {
                margin: var(--space-xl) 0;
                padding: var(--space-md);
                color: #5e5e5e
                font-size: var(--fs-base);
                font-weight: 800;
                text-align: center;
                letter-spacing: 0.05em;
            }

            /* SIGNATURE */
            .signature-section {
                margin-top: var(--sig-margin-t);
            }

            .sig-row {
                display: grid;
                gap: var(--sig-gap-x);
                margin-bottom: var(--sig-gap-y);
            }

            /* Helper Classes for Grid Columns */
            .sig-row-1 {
                grid-template-columns: repeat(1, 1fr);
            }
            .sig-row-2 {
                grid-template-columns: repeat(2, 1fr);
            }
            .sig-row-3 {
                grid-template-columns: repeat(3, 1fr);
            }
            .sig-row-4 {
                grid-template-columns: repeat(4, 1fr);
            }
            .sig-row-5 {
                grid-template-columns: repeat(5, 1fr);
            }

            /* Item Styling */
            .sig-item {
                text-align: center;
            }

            /* Signature Label */
            .sig-label {
                font-size: var(--fs-xs);
                font-weight: 700;
                color: #6b7280;
                text-transform: uppercase;
                margin-bottom: var(--space-xs);
            }

            /* Signature Line */
            .sig-line {
                border-bottom: 1px solid #9ca3af;
                min-height: calc(var(--fs-lg) * 1.5);
                /* make line relative to font size */
                font-weight: 600;
                font-size: var(--fs-base);
                color: #1f2937;
                padding-top: var(--space-xs);
                width: 100%;
                box-sizing: border-box;
                text-transform: uppercase;
            }

            /* Optional: Center helper for single or fewer signatures in a row */
            .sig-center {
                max-width: 50%;
                margin-left: auto;
                margin-right: auto;
            }
            /* PRINT */
            @media print {
                body {
                    background-color: white;
                }
                * {
                    -webkit-print-color-adjust: exact;
                    print-color-adjust: exact;
                }
            }
        </style>
    </head>
    <body class="variant-large">
        <div class="container">
            <header class="header">
                <h1>{{ header_title }}</h1>
                <p class="address">{{ header_address }}</p>
                <p class="tin">TIN: {{ tax_number }}</p>
                <h1 class="report-title">{{ report_title }}</h1>
            </header>

            <div class="info-grid grid-3">
                <div class="info-item">
                    <p>
                        <span class="info-label">Pay To:</span><span class="info-value">{{ pay_to }}</span>
                    </p>
                    <p>
                        <span class="info-label">Account No:</span><span class="info-value">{{ account_number }}</span>
                    </p>
                    <p>
                        <span class="info-label">Contact:</span><span class="info-value">{{ contact }}</span>
                    </p>
                </div>
                <div class="info-item">
                    <p>
                        <span class="info-label">Voucher No:</span><span class="info-value">{{ voucher_no }}</span>
                    </p>
                    <p>
                        <span class="info-label">Release Date:</span><span class="info-value">{{ date_release }}</span>
                    </p>
                    <p>
                        <span class="info-label">Terms:</span><span class="info-value">{{ terms }} ({{ mode_of_payment }})</span>
                    </p>
                    <p>
                        <span class="info-label">Collection:</span><span class="info-value">{{ collection }}</span>
                    </p>
                </div>
                <div class="info-item text-right">
                    <p>
                        <span class="info-label">Processor:</span><span class="info-value">{{ processor }}</span>
                    </p>
                    <p>
                        <span class="info-label">Due Date:</span><span class="info-value" style="color: #dc2626;">{{ due_date }}</span>
                    </p>
                </div>
            </div>

            <div class="table-wrapper">
              <table>
                    <thead>
                        <tr>
                            <th>Account Title</th>
                            <th>Description</th>
                            <th><p class="text-right">Debit</p></th>
                            <th><p class="text-right">Credit</p></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for entry in loan_transaction_entries %}
                            <tr class="{% if entry.is_highlighted %}highlight{% endif %}">
                                <td>{{ entry.account_title }}</td>
                                <td>{{ entry.description}}</td>
                                <td class="text-right">{{ entry.debit }}</td>
                                <td class="text-right">{{ entry.credit }}</td>
                            </tr>
                        {% endfor %}
                        <tr class="totals">
                            <td colspan="2">TOTAL</td>
                            <td class="text-right">{{ total_debit }}</td>
                            <td class="text-right">{{ total_credit }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="amount-words">
            *** {{ total_amount_in_words }} ONLY ***
        </div>

            <div class="check-details">
                <div>
                    <span class="info-label">Check No:</span>
                    <span class="info-value">{{ check_number }}</span>
                </div>

                <div>
                    <span class="info-label payment-label-offset">Check Date:</span>
                    <span class="info-value">{{ check_date }}</span>
                </div>
            </div>

            {% if print_count > 1 %}
                <div class="reprint-indicator">
                *** REPRINTED ({{ print_count }}) ***
            </div>
            {% endif %}

            <div class="signature-section">

                <div class="sig-row sig-row-3">
                    <div class="sig-item">
                        <p class="sig-label">Prepared</p>
                        <div class="sig-line">{{ prepared_by }}</div>
                    </div>
                    <div class="sig-item">
                        <p class="sig-label">Verified</p>
                        <div class="sig-line">{{ verified_by }}</div>
                    </div>
                    <div class="sig-item">
                        <p class="sig-label">Posted</p>
                        <div class="sig-line">{{ posted_by }}</div>
                    </div>
                </div>

                <div class="sig-row sig-row-2">
                    <div class="sig-item">
                        <p class="sig-label">Approved</p>
                        <div class="sig-line">{{ approved_by }}</div>
                    </div>
                    <div class="sig-item">
                        <p class="sig-label">Received By</p>
                        <div class="sig-line">{{ received_by }}</div>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>
