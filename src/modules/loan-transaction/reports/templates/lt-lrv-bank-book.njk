<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Loan Release Voucher</title>
        <style>
            @page {
                margin: 0;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body,
            html {
                margin: 0;
                padding: 0;
                min-height: 100%;
                background-color: #f9fafb;
            }

            body {
                display: flex;
                flex-direction: column;
            }

            .lrb-container {
                /* Preserved Variables */
                --fs-xs: 7px;
                --fs-sm: 8px;
                --fs-base: 9px;
                --fs-lg: 10px;
                --fs-xl: 12px;
                --fs-2xl: 14px;

                /* Adjusted for 125mm width */
                padding: 0.3in;
                background: white;
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
                color: #1f2937;
                font-size: var(--fs-sm);
                /* Using 8px as base for small paper */
                line-height: 1.3;
                flex-grow: 1;
                display: flex;
                flex-direction: column;
                width: 100%;
            }

            /* Header */
            .lrb-header {
                text-align: center;
                margin-bottom: 0.50rem;
                padding-bottom: 0.2rem;
                border-bottom: 1px solid #e5e7eb;
            }

            .lrb-header h1 {
                font-size: var(--fs-lg);
                font-weight: 800;
                color: #111827;
                margin-bottom: 0.05rem;
                letter-spacing: -0.01em;
            }

            .lrb-header .lrb-address {
                font-size: var(--fs-xs);
                color: #6b7280;
                margin: 0.05rem 0;
            }

            .lrb-header .lrb-tin {
                font-size: var(--fs-xs);
                color: #575656;
            }

            .lrb-report-title {
                font-size: var(--fs-xl);
                font-weight: 800;
                color: #111827;
                margin-top: 0.2rem;
                text-transform: uppercase;
                letter-spacing: 0.02em;
            }

            /* Info Grid - The "Good Looking" Section */
            .lrb-info-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 0.2rem;
                margin-bottom: 0.5rem;
            }

            .lrb-info-item p {
                display: flex;
                align-items: baseline;
                margin-bottom: 1px;
            }

            .lrb-info-label {
                font-size: var(--fs-xs);
                font-weight: 600;
                color: #575656;
                flex-shrink: 0;
            }

            .lrb-info-value {
                font-size: var(--fs-xs);
                color: #1f2937;
                font-weight: 700;
                padding-left: 2px;
                word-break: break-word;
            }

            /* Table */
            .lrb-table-wrapper {
                width: 100%;
                margin-bottom: 0.4rem;
            }

            .lrb-table-wrapper table {
                width: 100%;
                border-collapse: collapse;
                font-size: var(--fs-xs);
            }

            .lrb-table-wrapper th {
                text-transform: uppercase;
                font-weight: 700;
                color: #374151;
                padding: 0.25rem 0.15rem;
                border-bottom: 1px solid #e5e7eb;
            }

            .lrb-table-wrapper td {
                padding: 0.2rem 0.15rem;
                border-bottom: 1px solid #f3f4f6;
            }

            .lrb-text-right {
                text-align: right;
                font-family: monospace;
            }

            .lrb-highlight {
                background: #dbeafe !important;
                font-weight: 700;
                color: #1e40af;
            }

            .lrb-totals {
                background: #f3f4f6;
                font-weight: 700;
                border-top: 1px solid #9ca3af;
            }

            /* Amount in words */
            .lrb-amount-words {
                margin: 0.4rem 0;
                padding: 0.3rem;
                background: linear-gradient(to right, #fef3c7, #fde68a);
                border: 1px solid #fbbf24;
                border-radius: 2px;
                color: #78350f;
                font-size: var(--fs-xs);
                font-weight: 700;
                text-align: center;
            }

            /* Check Details */
            .lrb-check-details {
                display: flex;
                justify-content: space-around;
                margin-bottom: 0.6rem;
                padding: 0.2rem;
                border: 1px dashed #d1d5db;
                font-size: var(--fs-xs);
            }

            /* Signatures */
            .lrb-signature-section {
                margin-top: 1.5rem;
                padding-top: 0.4rem;
            }

            .lrb-sig-row-top {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 0.3rem;
                margin-bottom: 0.5rem;
            }

            .lrb-sig-row-bottom {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 1.5rem;
                padding: 0 5%;
            }

            .lrb-signature-item {
                text-align: center;
            }

            .lrb-signature-label {
                font-size: var(--fs-xs);
                font-weight: 700;
                color: #6b7280;
                text-transform: uppercase;
                margin-bottom: 2px;
            }

            .lrb-signature-line {
                border-bottom: 1px solid #9ca3af;
                min-height: 1rem;
                font-weight: 600;
                font-size: var(--fs-xs);
                color: #1f2937;
            }

            @media print {
                body {
                    background-color: white;
                }
                * {
                    -webkit-print-color-adjust: exact;
                    print-color-adjust: exact;
                }
            }
        </style>
    </head>
    <body>
        <div class="lrb-container">
            <header class="lrb-header">
                <h1>{{ header_title }}</h1>
                <p class="lrb-address">{{ header_address }}</p>
                <p class="lrb-tin">TIN: {{ tax_number }}</p>
                <h1 class="lrb-report-title">{{ report_title }}</h1>
            </header>

            <div class="lrb-info-grid">
                <div class="lrb-info-item">
                    <p>
                        <span class="lrb-info-label">Pay To:</span><span class="lrb-info-value">{{ pay_to }}</span></p>
                    <p>
                        <span class="lrb-info-label">Account No:</span><span class="lrb-info-value">{{ account_number }}</span></p>
                    <p>
                        <span class="lrb-info-label">Contact:</span><span class="lrb-info-value">{{ contact }}</span></p>
                </div>
                <div class="lrb-info-item">
                    <p>
                        <span class="lrb-info-label">Voucher No:</span><span class="lrb-info-value">{{ voucher_no }}</span></p>
                    <p>
                        <span class="lrb-info-label">Release Date:</span><span class="lrb-info-value">{{ date_release }}</span></p>
                    <p>
                        <span class="lrb-info-label">Terms:</span><span class="lrb-info-value">{{ terms }}  ({{ mode_of_payment }})</span></p>
                    <p>
                        <span class="lrb-info-label">Collection:</span><span class="lrb-info-value">{{ collection }}</span></p>
                </div>
                <div class="lrb-info-item">
                    <p>
                        <span class="lrb-info-label">Processor:</span><span class="lrb-info-value">{{ processor }}</span></p>
                    <p>
                        <span class="lrb-info-label">Due Date:</span><span class="lrb-info-value" style="color: #dc2626;">{{ due_date }}</span></p>
                </div>
            </div>

            <div class="lrb-table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Account Title</th>
                            <th class="lrb-text-right">Debit</th>
                            <th class="lrb-text-right">Credit</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for entry in loan_transaction_entries %}
                            <tr class="{% if entry.is_highlighted %}lrb-highlight{% endif %}">
                                <td>{{ entry.account_title }}</td>
                                <td class="lrb-text-right">{{ entry.debit }}</td>
                                <td class="lrb-text-right">{{ entry.credit }}</td>
                            </tr>
                        {% endfor %}
                        <tr class="lrb-totals">
                            <td>TOTAL</td>
                            <td class="lrb-text-right">{{ total_debit }}</td>
                            <td class="lrb-text-right">{{ total_credit }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="lrb-amount-words">
                *** {{ total_amount_in_words }} ***
            </div>

            <div class="lrb-check-details">
                <div>
                    <span class="lrb-info-label">Check Date:</span><span class="lrb-info-value">{{ check_date }}</span></div>
                <div>
                    <span class="lrb-info-label">Check #:</span><span class="lrb-info-value">{{ check_number }}</span></div>
            </div>

            <div class="lrb-signature-section">
                <div class="lrb-sig-row-top">
                    <div class="lrb-signature-item">
                        <p class="lrb-signature-label">Prepared</p>
                        <div class="lrb-signature-line">{{ prepared_by }}</div>
                    </div>
                    <div class="lrb-signature-item">
                        <p class="lrb-signature-label">Verified</p>
                        <div class="lrb-signature-line">{{ verified_by }}</div>
                    </div>
                    <div class="lrb-signature-item">
                        <p class="lrb-signature-label">Posted</p>
                        <div class="lrb-signature-line">{{ posted_by }}</div>
                    </div>
                </div>
                <div class="lrb-sig-row-bottom">
                    <div class="lrb-signature-item">
                        <p class="lrb-signature-label">Approved</p>
                        <div class="lrb-signature-line">{{ approved_by }}</div>
                    </div>
                    <div class="lrb-signature-item">
                        <p class="lrb-signature-label">Received</p>
                        <div class="lrb-signature-line">{{ received_by }}</div>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>
