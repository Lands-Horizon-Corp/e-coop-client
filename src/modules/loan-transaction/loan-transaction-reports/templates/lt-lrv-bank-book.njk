<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Loan Release Voucher - Bank Book</title>
        <style>
            @page {
                margin: 0;
            }
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            body,
            html {
                width: 100%;
                height: 100%;
                margin: 0;
                padding: 0;
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
                background: #f9fafb;
            }
            body {
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 0;
            }

            /* Main container: dynamic width/height from server/client, A5 padding */
            .lrb-container {
                width: 100%;
                height: 100%;
                max-width: 100%;
                max-height: 100%;
                padding: 8mm;
                /* <-- copied from A5 template */
                background: #fff;
                color: #1f2937;
                font-size: 0.8rem;
                line-height: 1.25;
                display: flex;
                flex-direction: column;
                box-sizing: border-box;
            }

            /* Header */
            .lrb-header {
                text-align: center;
                margin-bottom: 0.5em;
                border-bottom: 1px solid #e5e7eb;
                padding-bottom: 0.2em;
            }
            .lrb-header h1 {
                font-size: 1.1rem;
                font-weight: 800;
                color: #111827;
                margin-bottom: 0.2em;
                letter-spacing: -0.02em;
            }
            .lrb-header .lrb-address {
                font-size: 0.85rem;
                color: #6b7280;
            }
            .lrb-header .lrb-tin {
                font-size: 0.75rem;
                color: #9ca3af;
            }
            .lrb-header h2 {
                font-size: 0.8rem;
                font-weight: 700;
                text-transform: uppercase;
                margin-top: 0.25em;
            }

            /* Info Grid */
            .lrb-info-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(120px,1fr));
                gap: 0.5em;
                margin-bottom: 0.5em;
            }
            .lrb-info-item {
                font-size: 0.8rem;
            }
            .lrb-info-label {
                font-weight: 600;
                color: #374151;
            }
            .lrb-info-value {
                font-weight: 600;
                color: #1f2937;
                margin-left: 0.2em;
            }
            .lrb-info-subtext {
                font-size: 0.75rem;
                color: #6b7280;
                margin-top: 0.1em;
            }

            /* Table */
            .lrb-table-wrapper {
                width: 100%;
                margin-bottom: 0.5em;
                border-radius: 2px;
                overflow: hidden;
            }
            .lrb-table-wrapper table {
                width: 100%;
                border-collapse: collapse;
                font-size: 0.75rem;
            }
            .lrb-table-wrapper td,
            .lrb-table-wrapper th {
                padding: 0.3em 0.4em;
                border-bottom: 1px solid #e5e7eb;
            }
            .lrb-table-wrapper th {
                text-transform: uppercase;
                font-weight: 700;
                color: #374151;
                background: #f9fafb;
                text-align: left;
            }
            .lrb-text-right {
                text-align: right;
                font-family: 'Courier New', monospace;
                font-variant-numeric: tabular-nums;
            }
            .lrb-highlight {
                background: #dbeafe;
                font-weight: 700;
                color: #1e40af;
            }
            .lrb-totals {
                background: #f3f4f6;
                font-weight: 700;
                color: #111827;
                border-top: 1px solid #9ca3af;
            }

            /* Amount in words */
            .lrb-amount-words {
                margin: 0.5em 0;
                padding: 0.4em 0.3em;
                background: linear-gradient(to right,#fef3c7,#fde68a);
                border: 1px solid #fbbf24;
                border-radius: 2px;
                font-weight: 600;
                text-align: center;
            }

            /* Signature grid */
            .lrb-signature-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit,minmax(120px,1fr));
                gap: 1em;
                margin-top: 0.5em;
            }
            .lrb-signature-item {
                text-align: center;
            }
            .lrb-signature-label {
                font-size: 0.75rem;
                color: #6b7280;
                margin-bottom: 0.15em;
            }
            .lrb-signature-line {
                border-bottom: 1px solid #9ca3af;
                padding: 0.2em 0;
                min-height: 1em;
                font-weight: 500;
                color: #1f2937;
                margin-top: 0.15em;
            }

            /* Approval section */
            .lrb-approval-section {
                margin-top: 0.5em;
                text-align: center;
            }
            .lrb-approval-label {
                font-weight: 700;
                text-transform: uppercase;
                color: #111827;
                margin-bottom: 0.3em;
            }
            .lrb-approval-line {
                max-width: 10rem;
                margin: 0 auto;
                border-bottom: 1px solid #374151;
                padding: 0.2em 0;
                font-weight: 600;
                color: #1f2937;
            }

            @media print {
                body,
                html {
                    width: 100%;
                    height: 100%;
                }
                body {
                    background: white;
                }
                .lrb-container {
                    box-shadow: none;
                }
                * {
                    -webkit-print-color-adjust: exact;
                    print-color-adjust: exact;
                }
            }
        </style>
    </head>
    <body>
        <div class="lrb-container">
            <header class="lrb-header">
                <h1>{{ header_title }}</h1>
                <p class="lrb-address">{{ header_address }}</p>
                <p class="lrb-tin">TIN: {{ tax_number }}</p>
                <h2>{{ report_title }}</h2>
            </header>

            <div class="lrb-info-grid">
                <div class="lrb-info-item">
                    <div>
                        <span class="lrb-info-label">Pay To:</span>
                        <span class="lrb-info-value">{{ pay_to }}</span></div>
                    <p class="lrb-info-subtext">Account No: {{ account_number }}</p>
                    <p class="lrb-info-subtext">Contact: {{ contact }}</p>
                </div>
                <div class="lrb-info-item">
                    <p>
                        <span class="lrb-info-label">Voucher No:</span>
                        <span class="lrb-info-value">{{ voucher_no }}</span></p>
                    <p>
                        <span class="lrb-info-label">Release Date:</span>
                        <span class="lrb-info-value">{{ date_release }}</span></p>
                    <p>
                        <span class="lrb-info-label">Terms:</span>
                        <span class="lrb-info-value">{{ terms }} months ({{ mode_of_payment }})</span></p>
                </div>
                <div class="lrb-info-item">
                    <p>
                        <span class="lrb-info-label">Processor:</span>
                        <span class="lrb-info-value">{{ processor }}</span></p>
                    <p>
                        <span class="lrb-info-label">Due Date:</span>
                        <span class="lrb-info-value" style="color:#dc2626;">{{ due_date }}</span></p>
                </div>
            </div>

            <div class="lrb-table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Account Title</th>
                            <th class="lrb-text-right">Debit (₱)</th>
                            <th class="lrb-text-right">Credit (₱)</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for entry in loan_transaction_entries %}
                            <tr class="{% if entry.is_highlighted %}lrb-highlight{% endif %}">
                                <td>{{ entry.account_title }}</td>
                                <td class="lrb-text-right">{{ entry.debit }}</td>
                                <td class="lrb-text-right">{{ entry.credit }}</td>
                            </tr>
                        {% endfor %}
                        <tr class="lrb-totals">
                            <td>TOTAL</td>
                            <td class="lrb-text-right">{{ total_debit }}</td>
                            <td class="lrb-text-right">{{ total_credit }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="lrb-amount-words">*** {{ total_amount_in_words }} ONLY ***</div>

            <div class="lrb-signature-grid">
                <div class="lrb-signature-item">
                    <div class="lrb-signature-line">{{ prepared_by }}</div>
                    <p class="lrb-signature-label">Prepared by:</p>
                </div>
                <div class="lrb-signature-item">
                    <div class="lrb-signature-line">{{ payeee }}</div>
                    <p class="lrb-signature-label">Payee:</p>
                </div>
                <div class="lrb-signature-item">
                    <div class="lrb-signature-line">{{ cetified_correct }}</div>
                    <p class="lrb-signature-label">Certified Correct:</p>
                </div>
                <div class="lrb-signature-item">
                    <div class="lrb-signature-line">{{ paid_by }}</div>
                    <p class="lrb-signature-label">Paid by:</p>
                </div>
            </div>

            <div class="lrb-approval-section">
                <p class="lrb-approval-label">Approved for Payment:</p>
                <div class="lrb-approval-line">{{ approved_for_payment }}</div>
            </div>
        </div>
    </body>
</html>
