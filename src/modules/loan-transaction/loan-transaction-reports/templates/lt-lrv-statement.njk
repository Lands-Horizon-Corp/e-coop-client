<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loan Release Voucher - Statement</title>

    <style>
        @page {
            margin: 0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body,
        html {
            width: 100%;
            min-height: 100%;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
            background: #f3f4f6;
        }

        /* CONTAINER */
        .lrb-container {
            --fs-xs: 9px;
            --fs-sm: 10px;
            --fs-base: 11px;
            --fs-lg: 14px;
            --fs-xl: 16px;

            max-width: 800px; /* keeps approx A5 proportions */
            margin: auto;
            padding: 2rem;
            background: white;
            font-size: var(--fs-base);
            line-height: 1.4;
            display: flex;
            flex-direction: column;
        }

        /* HEADER */
        .lrb-header {
            text-align: center;
            margin-bottom: 1rem;
        }

        .lrb-header h1 {
            font-size: var(--fs-xl);
            font-weight: 700;
        }

        .lrb-address {
            font-size: var(--fs-sm);
            color: #6b7280;
        }

        .lrb-tin {
            font-size: var(--fs-xs);
            color: #9ca3af;
        }

        .lrb-report-title {
            font-size: 1.25rem;
            font-weight: 800;
            margin-top: 0.25rem;
        }

        /* INFO GRID */
        .lrb-info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 0.5rem;
            margin-bottom: 1rem;
            font-size: var(--fs-sm);
        }

        .lrb-info-label {
            font-size: var(--fs-xs);
            font-weight: 600;
        }

        .lrb-info-value {
            font-weight: 600;
        }

        .lrb-info-subtext {
            font-size: var(--fs-xs);
            color: #6b7280;
        }

        /* TABLE */
        .lrb-table-wrapper {
            width: 100%;
            margin-bottom: 1rem;
            overflow-x: auto;
            border: 1px solid #e5e7eb;
        }

        .lrb-table-wrapper table {
            width: 100%;
            border-collapse: collapse;
            font-size: var(--fs-sm);
            table-layout: auto;
        }

        .lrb-table-wrapper td,
        .lrb-table-wrapper th {
            padding: 0.4rem 0.5rem;
            border-bottom: 1px solid #e5e7eb;
            word-break: break-word;
            overflow-wrap: break-word;
        }

        .lrb-table-wrapper th {
            font-size: var(--fs-xs);
            font-weight: 700;
            text-transform: uppercase;
            background: #f9fafb;
        }

        .lrb-text-right {
            text-align: right;
            font-family: 'Courier New', monospace;
        }

        /* ROW STYLES */
        .lrb-highlight {
            background: #dbeafe;
            font-weight: 700;
        }

        .lrb-totals {
            background: #f3f4f6;
            font-weight: 700;
            border-top: 1px solid #6b7280;
        }

        /* AMOUNT */
        .lrb-amount-words {
            margin: 1rem 0;
            padding: 0.5rem;
            background: #fde68a;
            border: 1px solid #f59e0b;
            text-align: center;
            font-weight: 700;
        }

        /* SIGNATURES */
        .lrb-signature-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .lrb-signature-label {
            font-size: var(--fs-xs);
            color: #6b7280;
        }

        .lrb-signature-line {
            border-bottom: 1px solid #6b7280;
            margin-top: 0.3rem;
        }

        /* APPROVAL */
        .lrb-approval-section {
            margin-top: 1rem;
            text-align: center;
        }

        .lrb-approval-label {
            font-size: var(--fs-sm);
            font-weight: 700;
        }

        .lrb-approval-line {
            border-bottom: 1px solid #000;
            max-width: 12rem;
            margin: 0.25rem auto 0;
        }

        @media print {
            * {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            body {
                background: white;
            }

            .lrb-container {
                margin: 0;
                padding: 1rem;
                max-width: 100%;
            }
        }
    </style>
</head>

<body>
    <div class="lrb-container">

        <header class="lrb-header">
            <h1>{{ header_title }}</h1>
            <p class="lrb-address">{{ header_address }}</p>
            <p class="lrb-tin">TIN: {{ tax_number }}</p>
            <h1 class="lrb-report-title">{{ report_title }}</h1>
        </header>

        <div class="lrb-info-grid">
            <div>
                <span class="lrb-info-label">Pay To:</span>
                <span class="lrb-info-value">{{ pay_to }}</span>
                <p class="lrb-info-subtext">Account No: {{ account_number }}</p>
                <p class="lrb-info-subtext">Contact: {{ contact }}</p>
            </div>

            <div>
                <p>
                    <span class="lrb-info-label">Voucher No:</span>
                    <span class="lrb-info-value">{{ voucher_no }}</span>
                </p>
                <p>
                    <span class="lrb-info-label">Release Date:</span>
                    <span class="lrb-info-value">{{ date_release }}</span>
                </p>
                <p>
                    <span class="lrb-info-label">Terms:</span>
                    <span class="lrb-info-value">{{ terms }} months ({{ mode_of_payment }})</span>
                </p>
            </div>

            <div>
                <p>
                    <span class="lrb-info-label">Processor:</span>
                    <span class="lrb-info-value">{{ processor }}</span>
                </p>
                <p>
                    <span class="lrb-info-label">Due Date:</span>
                    <span class="lrb-info-value" style="color:#dc2626;">{{ due_date }}</span>
                </p>
            </div>
        </div>

        <div class="lrb-table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Account Title</th>
                        <th class="lrb-text-right">Debit (₱)</th>
                        <th class="lrb-text-right">Credit (₱)</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in loan_transaction_entries %}
                    <tr class="{% if item.is_highlighted %}lrb-highlight{% endif %}">
                        <td>{{ item.account_title }}</td>
                        <td class="lrb-text-right">{{ item.debit }}</td>
                        <td class="lrb-text-right">{{ item.credit }}</td>
                    </tr>
                    {% endfor %}
                    <tr class="lrb-totals">
                        <td>TOTAL</td>
                        <td class="lrb-text-right">{{ total_debit }}</td>
                        <td class="lrb-text-right">{{ total_credit }}</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="lrb-amount-words">*** {{ total_amount_in_words }} ONLY ***</div>

        <div class="lrb-signature-grid">
            <div>
                <div class="lrb-signature-line">{{ prepared_by }}</div>
                <p class="lrb-signature-label">Prepared by:</p>
            </div>
            <div>
                <div class="lrb-signature-line">{{ payeee }}</div>
                <p class="lrb-signature-label">Payee:</p>
            </div>
            <div>
                <div class="lrb-signature-line">{{ cetified_correct }}</div>
                <p class="lrb-signature-label">Certified Correct:</p>
            </div>
            <div>
                <div class="lrb-signature-line">{{ paid_by }}</div>
                <p class="lrb-signature-label">Paid by:</p>
            </div>
        </div>

        <div class="lrb-approval-section">
            <p class="lrb-approval-label">Approved for Payment:</p>
            <div class="lrb-approval-line">{{ approved_for_payment }}</div>
        </div>

    </div>
</body>
</html>
