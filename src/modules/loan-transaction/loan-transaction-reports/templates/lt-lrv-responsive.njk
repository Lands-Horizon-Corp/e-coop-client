<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Loan Release Voucher - Responsive</title>

        <style>
            @page {
                margin: 0;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            .lrb-container {
                --fs-xs: clamp(0.45rem, 0.60vw + 0.15vh, 0.65rem);
                --fs-sm: clamp(0.55rem, 0.75vw + 0.25vh, 0.75rem);
                --fs-base: clamp(0.65rem, 0.90vw + 0.30vh, 0.85rem);
                --fs-lg: clamp(0.75rem, 1.10vw + 0.40vh, 0.95rem);
                --fs-xl: clamp(0.85rem, 1.50vw + 0.55vh, 1.25rem);

                width: 100%;
                height: 100%;
                background: white;

                /* ✅ FIXED: match A5 feel instead of huge padding */
                padding: 8mm;

                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
                color: #1f2937;
                font-size: var(--fs-base);
                line-height: 1.35;

                display: flex;
                flex-direction: column;
            }

            /* HEADER */
            .lrb-header {
                text-align: center;
                margin-bottom: 0.5em;
                padding-bottom: 0.3em;
                border-bottom: 1px solid #e5e7eb;
            }

            .lrb-header h1 {
                font-size: var(--fs-lg);
                font-weight: 800;
            }

            .lrb-header .lrb-address {
                font-size: var(--fs-sm);
                color: #6b7280;
            }

            .lrb-header .lrb-tin {
                font-size: var(--fs-xs);
                color: #9ca3af;
            }

            .lrb-header h2 {
                font-size: var(--fs-xl);
                font-weight: 800;
                text-transform: uppercase;
            }

            /* INFO GRID */
            .lrb-info-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 0.5em;
                margin-bottom: 0.5em;
                font-size: var(--fs-sm);
            }

            .lrb-info-item {
                padding: 0.2em;
            }

            .lrb-info-label {
                font-weight: 600;
                color: #374151;
            }

            .lrb-info-value {
                font-weight: 600;
                padding-left: 0.25em;
            }

            .lrb-info-subtext {
                font-size: var(--fs-xs);
                color: #6b7280;
            }

            /* TABLE */
            .lrb-table-wrapper {
                width: 100%;
                margin-bottom: 0.5em;
                overflow: hidden;
                /* ✅ no scroll */
            }

            .lrb-table-wrapper table {
                width: 100%;
                border-collapse: collapse;
                table-layout: fixed;
                /* ✅ force fit */
                font-size: var(--fs-sm);
            }

            .lrb-table-wrapper td,
            .lrb-table-wrapper th {
                padding: 0.25em 0.3em;
                border-bottom: 1px solid #e5e7eb;

                word-break: break-word;
                overflow-wrap: break-word;
            }

            .lrb-table-wrapper th {
                text-transform: uppercase;
                font-size: var(--fs-xs);
                font-weight: 700;
                background: #f9fafb;
            }

            /* column control */
            .lrb-table-wrapper td:first-child {
                width: 55%;
            }

            .lrb-table-wrapper td:nth-child(2),
            .lrb-table-wrapper td:nth-child(3) {
                width: 22.5%;
            }

            .lrb-text-right {
                text-align: right;
                font-family: 'Courier New', monospace;
                font-variant-numeric: tabular-nums;
            }

            .lrb-highlight {
                background: #dbeafe;
                font-weight: 700;
            }

            .lrb-totals {
                background: #f3f4f6;
                font-weight: 700;
                border-top: 1px solid #9ca3af;
            }

            /* AMOUNT */
            .lrb-amount-words {
                margin: 0.5em 0;
                padding: 0.3em;
                background: #fde68a;
                border: 1px solid #fbbf24;
                text-align: center;
                font-size: var(--fs-base);
                font-weight: 600;
            }

            /* SIGNATURES */
            .lrb-signature-grid {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 0.5em;
                margin-top: 0.5em;
            }

            .lrb-signature-item {
                text-align: center;
            }

            .lrb-signature-label {
                font-size: var(--fs-xs);
                color: #6b7280;
            }

            .lrb-signature-line {
                border-bottom: 1px solid #9ca3af;
                min-height: 1em;
                margin-top: 0.2em;
            }

            /* APPROVAL */
            .lrb-approval-section {
                margin-top: 0.5em;
                text-align: center;
            }

            .lrb-approval-label {
                font-weight: 700;
                text-transform: uppercase;
            }

            .lrb-approval-line {
                border-bottom: 1px solid #374151;
                max-width: 10rem;
                margin: 0 auto;
            }

            @media print {
                * {
                    -webkit-print-color-adjust: exact;
                    print-color-adjust: exact;
                }
            }
        </style>
    </head>

    <body>
        <div class="lrb-container">

            <header class="lrb-header">
                <h1>{{header_title}}</h1>
                <p class="lrb-address">{{header_address}}</p>
                <p class="lrb-tin">TIN: {{tax_number}}</p>
                <h2>{{report_title}}</h2>
            </header>

            <div class="lrb-info-grid">
                <div class="lrb-info-item">
                    <div>
                        <span class="lrb-info-label">Pay To:</span>
                        <span class="lrb-info-value">{{pay_to}}</span>
                    </div>
                    <p class="lrb-info-subtext">Account No: {{account_number}}</p>
                    <p class="lrb-info-subtext">Contact: {{contact}}</p>
                </div>

                <div class="lrb-info-item">
                    <p>
                        <span class="lrb-info-label">Voucher No:</span>
                        <span class="lrb-info-value">{{voucher_no}}</span></p>
                    <p>
                        <span class="lrb-info-label">Release Date:</span>
                        <span class="lrb-info-value">{{date_release}}</span></p>
                    <p>
                        <span class="lrb-info-label">Terms:</span>
                        <span class="lrb-info-value">{{terms}} months ({{mode_of_payment}})</span></p>
                </div>

                <div class="lrb-info-item">
                    <p>
                        <span class="lrb-info-label">Processor:</span>
                        <span class="lrb-info-value">{{processor}}</span></p>
                    <p>
                        <span class="lrb-info-label">Due Date:</span>
                        <span class="lrb-info-value" style="color:#dc2626;">{{due_date}}</span></p>
                </div>
            </div>

            <div class="lrb-table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Account Title</th>
                            <th class="lrb-text-right">Debit (₱)</th>
                            <th class="lrb-text-right">Credit (₱)</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for entry in loan_transaction_entries %}
                            <tr class="{% if entry.is_highlighted %}lrb-highlight{% endif %}">
                                <td>{{ entry.account_title }}</td>
                                <td class="lrb-text-right">{{ entry.debit }}</td>
                                <td class="lrb-text-right">{{ entry.credit }}</td>
                            </tr>
                        {% endfor %}

                        <tr class="lrb-totals">
                            <td>TOTAL</td>
                            <td class="lrb-text-right">{{total_debit}}</td>
                            <td class="lrb-text-right">{{total_credit}}</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="lrb-amount-words">
*** {{total_amount_in_words}} ONLY ***
</div>

            <div class="lrb-signature-grid">
                <div class="lrb-signature-item">
                    <div class="lrb-signature-line">{{prepared_by}}</div>
                    <p class="lrb-signature-label">Prepared by:</p>
                </div>
                <div class="lrb-signature-item">
                    <div class="lrb-signature-line">{{payeee}}</div>
                    <p class="lrb-signature-label">Payee:</p>
                </div>
                <div class="lrb-signature-item">
                    <div class="lrb-signature-line">{{cetified_correct}}</div>
                    <p class="lrb-signature-label">Certified Correct:</p>
                </div>
                <div class="lrb-signature-item">
                    <div class="lrb-signature-line">{{paid_by}}</div>
                    <p class="lrb-signature-label">Paid by:</p>
                </div>
            </div>

            <div class="lrb-approval-section">
                <p class="lrb-approval-label">Approved for Payment:</p>
                <div class="lrb-approval-line">{{approved_for_payment}}</div>
            </div>

        </div>
    </body>
</html>
