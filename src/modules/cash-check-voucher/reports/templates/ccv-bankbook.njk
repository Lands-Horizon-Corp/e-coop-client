<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Cash Check Voucher</title>
        <style>
            @page {
                margin: 0;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body,
            html {
                margin: 0;
                padding: 0;
                height: 100%;
                background-color: #f9fafb;
            }

            body {
                display: flex;
                flex-direction: column;
            }

            .voucher-container {
                /* Preserving variables - optimized for 125mm x 176mm */
                --fs-xs: 7px;
                --fs-sm: 8px;
                --fs-base: 9px;
                --fs-lg: 10px;
                --fs-xl: 12px;
                --fs-2xl: 14px;

                padding: 0.3in;
                /* Tighter padding for smaller paper size */
                background: white;
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
                color: #1f2937;
                font-size: var(--fs-sm);
                line-height: 1.2;
                width: 100%;
                display: flex;
                flex-direction: column;
                flex-grow: 1;
            }

            /* Header */
            .voucher-header {
                text-align: center;
                margin-bottom: 0.25rem;
                padding-bottom: 0.2rem;
                border-bottom: 1px solid #e5e7eb;
            }

            .voucher-header h1 {
                font-size: var(--fs-lg);
                font-weight: 800;
                color: #111827;
                text-transform: uppercase;
            }

            .voucher-header .header-address {
                font-size: var(--fs-xs);
                color: #6b7280;
            }

            .voucher-header .header-tin {
                font-size: var(--fs-xs);
                color: #575656;
            }

            .voucher-title {
                font-size: var(--fs-xl);
                font-weight: 800;
                color: #111827;
                margin-top: 0.2rem;
                text-transform: uppercase;
            }

            /* Info Grid - Standardized classes */
            .voucher-info-grid {
                display: grid;
                grid-template-columns: 1.2fr 1fr;
                gap: 0.3rem;
                margin-bottom: 0.4rem;
            }

            .info-group p {
                display: flex;
                align-items: baseline;
                margin-bottom: 1px;
            }

            .info-label {
                font-size: var(--fs-xs);
                font-weight: 600;
                color: #575656;
                width: 60px;
                /* Fixed width for alignment */
                flex-shrink: 0;
            }

            .info-value {
                font-size: var(--fs-xs);
                color: #1f2937;
                font-weight: 700;
                word-break: break-word;
            }

            .info-subtext {
                font-size: var(--fs-xs);
                color: #6b7280;
                margin-top: 1px;
                display: block;
            }

            /* Table Section */
            .voucher-table-wrapper {
                width: 100%;
                margin-bottom: 0.3rem;
            }

            .voucher-table-wrapper table {
                width: 100%;
                border-collapse: collapse;
                font-size: var(--fs-xs);
            }

            .voucher-table-wrapper th {
                text-transform: uppercase;
                font-weight: 700;
                color: #374151;
                padding: 0.2rem;
                border-bottom: 1px solid #e5e7eb;
                text-align: left;
            }

            .voucher-table-wrapper td {
                padding: 0.2rem;
                border-bottom: 1px solid #f3f4f6;
            }

            .text-right {
                text-align: right;
                font-family: monospace;
            }

            .voucher-totals {
                background: #f3f4f6;
                font-weight: 700;
                border-top: 1px solid #9ca3af;
            }

            /* Amount in Words */
            .voucher-amount-box {
                margin: 0.3rem 0;
                padding: 0.25rem;
                background: linear-gradient(to right, #fef3c7, #fde68a);
                border: 1px solid #fbbf24;
                border-radius: 2px;
                color: #78350f;
                font-size: var(--fs-xs);
                font-weight: 700;
                text-align: center;
            }

            /* Check Details */
            .voucher-check-details {
                display: flex;
                justify-content: space-around;
                margin-bottom: 0.5rem;
                padding: 0.2rem;
                border: 1px dashed #d1d5db;
                font-size: var(--fs-xs);
            }

            /* Signature Section */
            .voucher-signature-section {
                margin-top: 1rem;
                /* Closes the gap to content as requested */
            }

            .sig-row {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 1rem;
                margin-bottom: 0.6rem;
            }

            .sig-item {
                text-align: center;
            }

            .sig-label {
                font-size: var(--fs-xs);
                font-weight: 700;
                color: #6b7280;
                text-transform: uppercase;
                margin-bottom: 1px;
            }

            .sig-line {
                border-bottom: 1px solid #9ca3af;
                min-height: 0.8rem;
                font-weight: 600;
                font-size: var(--fs-xs);
                color: #1f2937;
            }

            @media print {
                body {
                    background-color: white;
                }
                * {
                    -webkit-print-color-adjust: exact;
                    print-color-adjust: exact;
                }
            }
        </style>
    </head>
    <body>
        <div class="voucher-container">
            <header class="voucher-header">
                <h1>{{ header_title }}</h1>
                <p class="header-address">{{ header_address }}</p>
                <p class="header-tin">TIN: {{ tax_number }}</p>
                <h2 class="voucher-title">{{ report_title }}</h2>
            </header>

            <div class="voucher-info-grid">
                <div class="info-group">
                    <p>
                        <span class="info-label">Pay To:</span>
                        <span class="info-value">{{ pay_to }}</span></p>
                    <span class="info-subtext">
                        <b>Addr:</b>
                        {{ address }}</span>
                    <span class="info-subtext">
                        <b>Partic:</b>
                        {{ particulars }}</span>
                </div>
                <div class="info-group">
                    <p>
                        <span class="info-label">Voucher No:</span>
                        <span class="info-value">{{ voucher_no }}</span></p>
                    <p>
                        <span class="info-label">Entry Date:</span>
                        <span class="info-value">{{ entry_date }}</span></p>
                    <p>
                        <span class="info-label">Date:</span>
                        <span class="info-value">{{ date }}</span></p>
                </div>
            </div>

            <div class="voucher-table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Account Title</th>
                            <th class="text-right">Debit</th>
                            <th class="text-right">Credit</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for entry in account_entries %}
                            <tr>
                                <td>{{ entry.account_title }}</td>
                                <td class="text-right">{{ entry.debit }}</td>
                                <td class="text-right">{{ entry.credit }}</td>
                            </tr>
                        {% endfor %}

                        {% if cash_on_hand_total_debit or cash_on_hand_total_credit %}
                            <tr style="background: #f8fafc; font-weight: 600;">
                                <td>CASH ON HAND TOTAL</td>
                                <td class="text-right">{{ cash_on_hand_total_debit }}</td>
                                <td class="text-right">{{ cash_on_hand_total_credit }}</td>
                            </tr>
                        {% endif %}

                        <tr class="voucher-totals">
                            <td>TOTAL</td>
                            <td class="text-right">{{ total_debit }}</td>
                            <td class="text-right">{{ total_credit }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="voucher-amount-box">
            *** {{ total_amount_into_words }} ONLY ***
        </div>

            <div class="voucher-check-details">
                <div>
                    <span class="info-label">Check Date:</span><span class="info-value">{{ check_date }}</span></div>
                <div>
                    <span class="info-label">Check No:</span><span class="info-value">{{ check_number }}</span></div>
            </div>

            <div class="voucher-signature-section">
                <div class="sig-row">
                    <div class="sig-item">
                        <p class="sig-label">Prepared By</p>
                        <div class="sig-line">{{ prepared_by }}</div>
                    </div>
                    <div class="sig-item">
                        <p class="sig-label">Payee / Received By</p>
                        <div class="sig-line">{{ payee }}</div>
                    </div>
                </div>
                <div class="sig-row">
                    <div class="sig-item">
                        <p class="sig-label">Certified Correct</p>
                        <div class="sig-line">{{ certified_correct }}</div>
                    </div>
                    <div class="sig-item">
                        <p class="sig-label">Paid By</p>
                        <div class="sig-line">{{ paid_by }}</div>
                    </div>
                </div>
                <div class="sig-row" style="grid-template-columns: 1fr; padding: 0 15%;">
                    <div class="sig-item">
                        <p class="sig-label">Approved for Payment</p>
                        <div class="sig-line">{{ approved_for_payment }}</div>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>
