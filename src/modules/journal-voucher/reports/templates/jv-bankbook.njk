<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Journal Voucher</title>
    <style>
        @page {
            size: 125mm 176mm;
            margin: 0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body,
        html {
            margin: 0;
            padding: 0;
            min-height: 100%;
            background-color: #f9fafb;
        }

        body {
            display: flex;
            flex-direction: column;
        }

        .jvv-container {
            /* Preserved Variables from Gold Standard */
            --fs-xs: 7px;
            --fs-sm: 8px;
            --fs-base: 9px;
            --fs-lg: 10px;
            --fs-xl: 12px;
            --fs-2xl: 14px;

            padding: 0.3in;
            background: white;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
            color: #1f2937;
            font-size: var(--fs-sm);
            line-height: 1.3;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            width: 100%;
        }

        /* Header Match */
        .jvv-header {
            text-align: center;
            margin-bottom: 0.50rem;
            padding-bottom: 0.2rem;
            border-bottom: 1px solid #e5e7eb;
        }

        .jvv-header h1 {
            font-size: var(--fs-lg);
            font-weight: 800;
            color: #111827;
            margin-bottom: 0.05rem;
            letter-spacing: -0.01em;
        }

        .jvv-header .jvv-address {
            font-size: var(--fs-xs);
            color: #6b7280;
            margin: 0.05rem 0;
        }

        .jvv-header .jvv-tin {
            font-size: var(--fs-xs);
            color: #575656;
        }

        .jvv-report-title {
            font-size: var(--fs-xl);
            font-weight: 800;
            color: #111827;
            margin-top: 0.2rem;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }

        /* Info Grid Match */
        .jvv-info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.2rem;
            margin-bottom: 0.5rem;
        }

        .jvv-info-item p {
            display: flex;
            align-items: baseline;
            margin-bottom: 1px;
        }

        .jvv-info-label {
            font-size: var(--fs-xs);
            font-weight: 600;
            color: #575656;
            flex-shrink: 0;
            min-width: 55px;
        }

        .jvv-info-value {
            font-size: var(--fs-xs);
            color: #1f2937;
            font-weight: 700;
            padding-left: 2px;
            word-break: break-word;
        }

        /* Table Match */
        .jvv-table-wrapper {
            width: 100%;
            margin-bottom: 0.4rem;
        }

        .jvv-table-wrapper table {
            width: 100%;
            border-collapse: collapse;
            font-size: var(--fs-xs);
        }

        .jvv-table-wrapper th {
            text-transform: uppercase;
            font-weight: 700;
            color: #374151;
            padding: 0.25rem 0.15rem;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
        }

        .jvv-table-wrapper td {
            padding: 0.2rem 0.15rem;
            border-bottom: 1px solid #f3f4f6;
        }

        .text-right {
            text-align: right;
            font-family: monospace;
        }

        .highlight {
            background: #dbeafe !important;
            font-weight: 700;
            color: #1e40af;
        }

        .totals {
            background: #f3f4f6;
            font-weight: 700;
            border-top: 1px solid #9ca3af;
        }

        /* Status Bar Match */
        .jvv-status-bar {
            margin: 0.4rem 0;
            padding: 0.3rem;
            background: linear-gradient(to right, #fef3c7, #fde68a);
            border: 1px solid #fbbf24;
            border-radius: 2px;
            color: #78350f;
            font-size: var(--fs-xs);
            font-weight: 700;
            text-align: center;
        }

        /* Signatures Match */
        .jvv-signature-section {
            margin-top: 1.5rem;
            padding-top: 0.4rem;
        }

        .jvv-sig-row {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
            padding: 0 5%;
        }

        .sig-item {
            text-align: center;
        }

        .sig-label {
            font-size: var(--fs-xs);
            font-weight: 700;
            color: #6b7280;
            text-transform: uppercase;
            margin-bottom: 2px;
        }

        .sig-line {
            border-bottom: 1px solid #9ca3af;
            min-height: 1rem;
            font-weight: 600;
            font-size: var(--fs-xs);
            color: #1f2937;
        }

        .jvv-footer {
            margin-top: auto;
            display: flex;
            justify-content: space-between;
            font-size: var(--fs-xs);
            color: #9ca3af;
            padding-top: 5px;
            border-top: 1px dotted #e5e7eb;
        }

        @media print {
            body { background-color: white; }
            * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        }
    </style>
</head>
<body>
    <div class="jvv-container">
        <header class="jvv-header">
            <h1>{{ header_title }}</h1>
            <p class="jvv-address">{{ header_address }}</p>
            <p class="jvv-tin">TIN: {{ tax_number }}</p>
            <h1 class="jvv-report-title">{{ report_title }}</h1>
        </header>

        <div class="jvv-info-grid">
            <div class="jvv-info-item">
                <p><span class="jvv-info-label">Name:</span><span class="jvv-info-value">{{ name }}</span></p>
                <p><span class="jvv-info-label" style="font-size: var(--fs-xs); font-weight: 400;">Particulars:</span><span class="jvv-info-value" style="font-weight: 400;">{{ particulars }}</span></p>
            </div>
            <div class="jvv-info-item" style="text-align: right;">
                <p style="justify-content: flex-end;"><span class="jvv-info-label">Voucher:</span><span class="jvv-info-value">{{ voucher_no }}</span></p>
                <p style="justify-content: flex-end;"><span class="jvv-info-label">Date:</span><span class="jvv-info-value">{{ entry_date }}</span></p>
            </div>
        </div>

        <div class="jvv-table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Account Title</th>
                        <th class="text-right">Debit</th>
                        <th class="text-right">Credit</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in account_entries %}
                        <tr class="{% if entry.is_highlighted %}highlight{% endif %}">
                            <td>{{ entry.account_title }}</td>
                            <td class="text-right">{{ entry.debit }}</td>
                            <td class="text-right">{{ entry.credit }}</td>
                        </tr>
                    {% endfor %}
                    <tr class="totals">
                        <td>TOTAL</td>
                        <td class="text-right">{{ total_debit }}</td>
                        <td class="text-right">{{ total_credit }}</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="jvv-status-bar">
            *** {{ status }} ({{ count }}) ***
        </div>

        <div class="jvv-signature-section">
            <div class="jvv-sig-row">
                <div class="sig-item">
                    <p class="sig-label">Prepared By</p>
                    <div class="sig-line">{{ prepared_by }}</div>
                </div>
                <div class="sig-item">
                    <p class="sig-label">Approved By</p>
                    <div class="sig-line">{{ approved_by }}</div>
                </div>
            </div>
        </div>

        <footer class="jvv-footer">
            <span>ID: {{ user_id }}</span>
            <span>{{ report_date }} | {{ time }}</span>
        </footer>
    </div>
</body>
</html>
