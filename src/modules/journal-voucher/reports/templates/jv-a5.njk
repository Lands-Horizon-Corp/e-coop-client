<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Journal Voucher</title>
    <style>
        @page {
            margin: 0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body,
        html {
            margin: 0;
            padding: 0;
            min-height: 100%;
            background-color: #f9fafb;
        }

        body {
            display: flex;
            flex-direction: column;
        }

        .jvv-container {
            /* Inherited Variables from Loan Template */
            --fs-xs: 7px;
            --fs-sm: 8px;
            --fs-base: 9px;
            --fs-lg: 10px;
            --fs-xl: 12px;
            --fs-2xl: 14px;

            padding: 0.3in;
            background: white;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
            color: #1f2937;
            font-size: var(--fs-base);
            line-height: 1.3;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            width: 100%;
        }

        /* Header Match */
        .jvv-header {
            text-align: center;
            margin-bottom: 0.3rem;
            padding-bottom: 0.15rem;
            border-bottom: 1px solid #e5e7eb;
        }

        .jvv-header h1 {
            font-size: var(--fs-xl);
            font-weight: 800;
            color: #111827;
            margin-bottom: 0.1rem;
            letter-spacing: -0.025em;
        }

        .jvv-header .jvv-address {
            font-size: var(--fs-base);
            color: #6b7280;
            margin: 0.1rem 0;
        }

        .jvv-header .jvv-tin {
            font-size: var(--fs-sm);
            color: #575656;
        }

        .jvv-report-title {
            font-size: var(--fs-2xl);
            font-weight: 800;
            color: #111827;
            margin-top: 0.25rem;
            letter-spacing: -0.025em;
            text-transform: uppercase;
        }

        /* Info Grid Match */
        .jvv-info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.15rem;
            margin-bottom: 0.4rem;
            font-size: var(--fs-base);
        }

        .jvv-info-item {
            padding: 0.08rem;
        }

        .jvv-info-label {
            font-size: var(--fs-sm);
            font-weight: 600;
            color: #575656;
            display: inline-block;
            min-width: 65px;
        }

        .jvv-info-value {
            font-size: var(--fs-base);
            color: #1f2937;
            font-weight: 600;
            padding-left: 0.25rem;
        }

        /* Table Match */
        .jvv-table-wrapper {
            width: 100%;
            margin-bottom: 0.3rem;
        }

        .jvv-table-wrapper table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            font-size: var(--fs-base);
        }

        .jvv-table-wrapper th {
            text-transform: uppercase;
            font-size: var(--fs-sm);
            font-weight: 700;
            color: #374151;
            padding: 0.3rem;
            text-align: left;
            border-bottom: 2px solid #e5e7eb;
        }

        .jvv-table-wrapper td {
            padding: 0.25rem 0.3rem;
            border-bottom: 1px solid #f3f4f6;
        }

        .text-right {
            text-align: right;
            font-family: 'SF Mono', 'Monaco', 'Courier New', monospace;
            font-variant-numeric: tabular-nums;
        }

        .highlight {
            background: #dbeafe !important;
            font-weight: 700;
            color: #1e40af;
            border-top: 1px solid #3b82f6;
            border-bottom: 1px solid #3b82f6;
        }

        .totals {
            background: #f3f4f6;
            font-weight: 700;
            color: #111827;
            font-size: var(--fs-base);
            border-top: 1px solid #9ca3af;
        }

        /* Status/Amount words Match */
        .jvv-status-bar {
            margin: 0.3rem 0;
            padding: 0.3rem 0.15rem;
            background: linear-gradient(to right, #fef3c7, #fde68a);
            border: 1px solid #fbbf24;
            border-radius: 0.15rem;
            color: #78350f;
            font-size: var(--fs-base);
            font-weight: 700;
            text-align: center;
            letter-spacing: 0.025em;
        }

        /* Signature Section Match */
        .jvv-signature-section {
            margin-top: 1.2rem;
            padding-top: 0.5rem;
        }

        .jvv-sig-row {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 2.5rem;
            padding: 0 5%;
        }

        .jvv-signature-item {
            text-align: center;
        }

        .jvv-signature-label {
            font-size: var(--fs-sm);
            font-weight: 700;
            color: #6b7280;
            margin-bottom: 0.15rem;
            text-transform: uppercase;
        }

        .jvv-signature-line {
            border-bottom: 1px solid #9ca3af;
            padding: 0.15rem 0;
            min-height: 1.2rem;
            font-weight: 600;
            font-size: var(--fs-base);
            color: #1f2937;
            margin-top: 0.15rem;
        }

        /* Footer */
        .jvv-footer {
            margin-top: auto;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            font-size: var(--fs-xs);
            color: #9ca3af;
            border-top: 1px dotted #e5e7eb;
            padding-top: 5px;
        }

        @media print {
            body { background-color: white; }
            * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        }
    </style>
</head>
<body>
    <div class="jvv-container">
        <header class="jvv-header">
            <h1>{{ header_title }}</h1>
            <p class="jvv-address">{{ header_address }}</p>
            <p class="jvv-tin">TIN: {{ tax_number }}</p>
            <h1 class="jvv-report-title">{{ report_title }}</h1>
        </header>

        <div class="jvv-info-grid">
            <div class="jvv-info-item">
                <p><span class="jvv-info-label">Name:</span><span class="jvv-info-value">{{ name }}</span></p>
                <p><span class="jvv-info-label" style="font-size: var(--fs-xs);">Particulars:</span><span class="jvv-info-value" style="font-weight: 400;">{{ particulars }}</span></p>
            </div>
            <div class="jvv-info-item" style="text-align: right;">
                <p><span class="jvv-info-label">Voucher No:</span><span class="jvv-info-value">{{ voucher_no }}</span></p>
                <p><span class="jvv-info-label">Entry Date:</span><span class="jvv-info-value">{{ entry_date }}</span></p>
            </div>
        </div>

        <div class="jvv-table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Account Title</th>
                        <th class="text-right">Debit (₱)</th>
                        <th class="text-right">Credit (₱)</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in account_entries %}
                        <tr class="{% if entry.is_highlighted %}highlight{% endif %}">
                            <td>{{ entry.account_title }}</td>
                            <td class="text-right">{{ entry.debit }}</td>
                            <td class="text-right">{{ entry.credit }}</td>
                        </tr>
                    {% endfor %}
                    <tr class="totals">
                        <td>TOTAL</td>
                        <td class="text-right">{{ total_debit }}</td>
                        <td class="text-right">{{ total_credit }}</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="jvv-status-bar">
            *** {{ status }} ({{ count }}) ***
        </div>

        <div class="jvv-signature-section">
            <div class="jvv-sig-row">
                <div class="jvv-signature-item">
                    <p class="jvv-signature-label">Prepared By</p>
                    <div class="jvv-signature-line">{{ prepared_by }}</div>
                </div>
                <div class="jvv-signature-item">
                    <p class="jvv-signature-label">Approved By</p>
                    <div class="jvv-signature-line">{{ approved_by }}</div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
