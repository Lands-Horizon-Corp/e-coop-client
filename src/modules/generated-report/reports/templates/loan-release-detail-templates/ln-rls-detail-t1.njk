<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Transaction Batch Report</title>
        <style>
            @page {
                margin: 0.5in;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body,
            html {
                margin: 0;
                padding: 0;
                min-height: 100%;
                background-color: white;
            }

            body {
                margin: 0;
                padding: 0;
                height: auto;
                /* Change from min-height: 100% */
                display: block;
            }

            /* BASE VARS AT TOKEN */
            .container {
                /* FONT SCALE */
                --fs-xs: 7px;
                --fs-sm: 8px;
                --fs-base: 9px;
                --fs-lg: 10px;
                --fs-xl: 12px;
                --fs-2xl: 14px;

                /* SPACING SCALE */
                --space-xs: 0.08rem;
                --space-sm: 0.15rem;
                --space-md: 0.25rem;
                --space-lg: 0.3rem;
                --space-xl: 0.4rem;

                /* LAYOUT */
                --container-padding: 0.3in;
                --line-height: 1.3;

                --sig-gap-x: 0.7rem;
                --sig-gap-y: 1.4rem;
                --sig-margin-t: 2rem;

                padding: var(--container-padding);
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
                font-size: var(--fs-base);
                line-height: var(--line-height);

                display: flex;
                flex-direction: column;
                justify-content: flex-start;
                /* FORCE content to the top */
                align-items: stretch;
                width: 100%;
            }

            /* DENSITY VARIANTS */

            /* NORMAL (default, explicit if you want) */
            .normal .container {
                --fs-xs: 7px;
                --fs-sm: 8px;
                --fs-base: 9px;
                --fs-lg: 10px;
                --fs-xl: 12px;
                --fs-2xl: 14px;

                --space-xs: 0.08rem;
                --space-sm: 0.15rem;
                --space-md: 0.25rem;
                --space-lg: 0.3rem;
                --space-xl: 0.4rem;

                --sig-gap-x: 0.7rem;
                --sig-gap-y: 1.4rem;
                --sig-margin-t: 2rem;

                --container-padding: 0.3in;
                --line-height: 1.3;
            }

            /* COMPACT */
            .compact .container {
                --fs-xs: 6px;
                --fs-sm: 7px;
                --fs-base: 8px;
                --fs-lg: 9px;
                --fs-xl: 10px;
                --fs-2xl: 12px;

                --space-xs: 0.05rem;
                --space-sm: 0.1rem;
                --space-md: 0.15rem;
                --space-lg: 0.2rem;
                --space-xl: 0.25rem;

                --sig-gap-x: 0.3rem;
                --sig-gap-y: 1rem;
                --sig-margin-t: 1.4rem;

                --container-padding: 0.15in;
                --line-height: 1.2;
            }

            /* LARGER */
            .loose .container {
                --fs-xs: 8px;
                --fs-sm: 10px;
                --fs-base: 12px;
                --fs-lg: 14px;
                --fs-xl: 16px;
                --fs-2xl: 18px;

                --space-xs: 0.1rem;
                --space-sm: 0.2rem;
                --space-md: 0.3rem;
                --space-lg: 0.4rem;
                --space-xl: 0.5rem;

                --sig-gap-x: 1.8rem;
                --sig-gap-y: 2rem;
                --sig-margin-t: 1rem;

                --container-padding: 0.4in;
                --line-height: 1.4;
            }

            /* HEADER */
            .header {
                text-align: center;
                margin-bottom: var(--space-lg);
                padding-bottom: var(--space-sm);
                /* border-bottom: 1px solid #e5e7eb; */
            }

            .header h1 {
                font-size: var(--fs-xl);
                font-weight: 800;
                margin-bottom: var(--space-xs);
                letter-spacing: -0.025em;
            }

            .header .address {
                font-size: var(--fs-base);
                margin: var(--space-xs) 0;
            }

            .header .tin {
                font-size: var(--fs-sm);
            }

            .report-title {
                font-size: var(--fs-2xl);
                font-weight: 800;
                margin-top: var(--space-sm);
                letter-spacing: -0.025em;
                text-transform: uppercase;
            }

            .center {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                text-align: center;
            }

            /* TABLE */
            .table {
                width: 100%;
                margin-top: var(--space-xl);
                margin-bottom: var(--space-lg);
                border: 0;
                border-radius: 6px;
                overflow: hidden;
                font-size: var(--fs-base);
                border-collapse: collapse;
                box-shadow: inset 0 0 0 1px #e5e7eb;
            }

            .table th {
                text-transform: uppercase;
                font-size: var(--fs-sm);
                font-weight: 700;
                padding: var(--space-lg);
                text-align: left;
                border-bottom: 2px solid #e5e7eb;
            }

            .table td {
                padding: var(--space-md) var(--space-lg);
                border-bottom: 1px solid #f3f4f6;
            }

            .bold {
                font-weight: 900;
            }

            .text-right {
                text-align: right !important;
                font-family: 'SF Mono', 'Monaco', 'Courier New', monospace;
                font-variant-numeric: tabular-nums;
            }

            .italic {
                font-style: italic;
            }

            {
                # SIG #
            }

            /* SIGNATURE */
            .signature-section {
                margin-top: var(--sig-margin-t);
            }

            .sig-row {
                display: grid;
                gap: var(--sig-gap-x);
                margin-bottom: var(--sig-gap-y);
            }

            /* Helper Classes for Grid Columns */
            .sig-row-1 {
                grid-template-columns: repeat(1, 1fr);
            }
            .sig-row-2 {
                grid-template-columns: repeat(2, 1fr);
            }
            .sig-row-3 {
                grid-template-columns: repeat(3, 1fr);
            }
            .sig-row-4 {
                grid-template-columns: repeat(4, 1fr);
            }
            .sig-row-5 {
                grid-template-columns: repeat(5, 1fr);
            }

            /* Item Styling */
            .sig-item {
                text-align: center;
            }

            /* Signature Label */
            .sig-label {
                font-size: var(--fs-xs);
                font-weight: 700;
                text-transform: uppercase;
                margin-bottom: var(--space-xs);
            }

            /* Signature Line */
            .sig-line {
                border-bottom: 1px solid #9ca3af;
                min-height: calc(var(--fs-lg) * 1.5);
                font-weight: 600;
                font-size: var(--fs-base);
                padding-top: var(--space-xs);
                width: 100%;
                box-sizing: border-box;
                text-transform: uppercase;
            }

            /* Optional: Center helper for single or fewer signatures in a row */
            .sig-center {
                max-width: 50%;
                margin-left: auto;
                margin-right: auto;
            }

            .page-break {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 100%;
                margin: 20px 0;
                border-top: 1px dashed #ccc;
                height: 1px;
                position: relative;
            }

            .page-break::after {
                content: 'next page';
                position: absolute;
                background: #fff;
                padding: 0 10px;
                font-size: 10px;
                color: #999;
            }

            /* PRINT */
            @media print {
                body {
                    background-color: white;
                }
                * {
                    -webkit-print-color-adjust: exact;
                    print-color-adjust: exact;
                }

                .container {
                    padding: 0 !important;
                    margin: 0 !important;
                }

                .page-break {
                    display: block;
                    page-break-after: always;
                    break-after: page;

                    border: none;
                    height: 0;
                    margin: 0;
                }

                .page-break::after {
                    content: '';
                }
            }
        </style>
    </head>
    <body class="{{ density | default('normal') }}">
        <div class="container">
            <header class="header">
                <h1>{{ header_title }}</h1>
                <p class="address">{{ header_address }}</p>
                <p class="tin">TIN: {{ tax_number }}</p>
            </header>

            <div class="center">
                <h2 class="bold">{{ report_title }}</h2>

                <div class="subtext">
                    {{ mode_of_payment }} - FROM: {{ start_date }} TO: {{ end_date }}
                </div>
            </div>

            {% set is_set_1 = grouping == 'by_mtype_acct'%}

            {% set is_set_2 = grouping == 'by_mtype_brgy'
            or grouping == 'by_coll_area'
            or grouping == 'by_mtype_mclass'
            or grouping == 'by_coll_brgy'
            or grouping == 'by_mtype_occup'
            or grouping == 'no_grouping'
 %}

            {% set is_set_3 = grouping == 'by_mclass_area_mtype_grp'
            or grouping == 'by_mtype_area'
            or grouping == 'by_mtype_ltype'
            or grouping == 'by_mtype_area_grp'
 %}

            {% set is_set_4 = grouping == 'by_mtype_acct_ltr' %}

            <!-- MACRO : TABLE HEAD -->
            {% macro render_table_head() %}
                <thead>
                    <tr>
                        {% if is_set_1 %}
                            <th>PB No.</th>
                            <th>Member Name</th>
                            <th>CV No.</th>
                            <th>Release Date</th>
                            <th>Due Date</th>
                            <th>First Pay</th>
                            <th>Terms</th>
                            <th>Pay Mode</th>
                            <th class="text-right">Amortization</th>
                            <th class="text-right">Current</th>
                            <th class="text-right">Restruct</th>
                            <th class="text-right">Renewal</th>
                        {% endif %}

                        {% if is_set_2 %}
                            <th>PB No.</th>
                            <th>Member Name</th>
                            <th>Loan Type</th>
                            <th>CV No.</th>
                            <th>Release Date</th>
                            <th>Due Date</th>
                            <th>First Pay</th>
                            <th>Terms</th>
                            <th>Pay Mode</th>
                            <th class="text-right">Amortization</th>
                            <th class="text-right">Current</th>
                            <th class="text-right">Restruct</th>
                            <th class="text-right">Renewal</th>
                        {% endif %}

                        {% if is_set_3 %}
                            <th>Member Name</th>
                            <th>Loan Type</th>
                            <th>Date Granted</th>
                            <th>Terms</th>
                            <th>Maturity Date</th>
                            <th>Payment Mode</th>
                            <th class="text-right">Amount Applied</th>
                            <th class="text-right">Interest on Loan</th>
                            <th class="text-right">Amount Granted</th>
                        {% endif %}

                        {% if is_set_4 %}
                            <th>PB No.</th>
                            <th>Member Name</th>
                            <th>Release Date</th>
                            <th>Due Date</th>
                            <th>Pay Mode</th>
                            <th class="text-right">Amortization</th>
                            <th class="text-right">Granted</th>
                            <th class="text-right">RL</th>
                            <th class="text-right">CCL</th>
                            <th class="text-right">ML</th>
                            <th class="text-right">CMKR</th>
                            <th class="text-right">BOD</th>
                            <th class="text-right">CMC</th>
                            <th class="text-right">Legal</th>
                        {% endif %}
                    </tr>
                </thead>
            {% endmacro %}

            <!-- MACRO : DATA ENTRIES -->
            {% macro render_data_entries(entries) %}
                {% for entry in entries %}
                    <tr>
                        {% if is_set_1 %}
                            <td>{{ entry.passbook }}</td>
                            <td>{{ entry.member_fullname }}</td>
                            <td>{{ entry.cv_no }}</td>
                            <td>{{ entry.release_date }}</td>
                            <td>{{ entry.due_date }}</td>
                            <td>{{ entry.firt_pay_date }}</td>
                            <td>{{ entry.terms }}</td>
                            <td>{{ entry.mode_of_payment }}</td>
                            <td class="text-right">{{ entry.amortization }}</td>
                            <td class="text-right">{{ entry.current }}</td>
                            <td class="text-right">{{ entry.restructured }}</td>
                            <td class="text-right">{{ entry.renewal }}</td>
                        {% endif %}

                        {% if is_set_2 %}
                            <td>{{ entry.passbook }}</td>
                            <td>{{ entry.member_fullname }}</td>
                            <td>{{ entry.loan_type }}</td>
                            <td>{{ entry.cv_no }}</td>
                            <td>{{ entry.release_date }}</td>
                            <td>{{ entry.due_date }}</td>
                            <td>{{ entry.firt_pay_date }}</td>
                            <td>{{ entry.terms }}</td>
                            <td>{{ entry.mode_of_payment }}</td>
                            <td class="text-right">{{ entry.amortization }}</td>
                            <td class="text-right">{{ entry.current }}</td>
                            <td class="text-right">{{ entry.restructured }}</td>
                            <td class="text-right">{{ entry.renewal }}</td>
                        {% endif %}

                        {% if is_set_3 %}
                            <td>{{ entry.member_fullname }}</td>
                            <td>{{ entry.loan_type }}</td>
                            <td>{{ entry.date_granted }}</td>
                            <td>{{ entry.terms }}</td>
                            <td>{{ entry.maturity_date }}</td>
                            <td>{{ entry.mode_of_payment }}</td>
                            <td class="text-right">{{ entry.amount_applied }}</td>
                            <td class="text-right">{{ entry.interest_on_loan }}</td>
                            <td class="text-right">{{ entry.amount_granted }}</td>
                        {% endif %}

                        {% if is_set_4 %}
                            <td>{{ entry.passbook }}</td>
                            <td>{{ entry.member_fullname }}</td>
                            <td>{{ entry.release_date }}</td>
                            <td>{{ entry.due_date }}</td>
                            <td>{{ entry.mode_of_payment }}</td>
                            <td class="text-right">{{ entry.amortization }}</td>
                            <td class="text-right">{{ entry.amount_granted }}</td>
                            <td class="text-right">{{ entry.rl }}</td>
                            <td class="text-right">{{ entry.ccl }}</td>
                            <td class="text-right">{{ entry.ml }}</td>
                            <td class="text-right">{{ entry.cmkr }}</td>
                            <td class="text-right">{{ entry.bod }}</td>
                            <td class="text-right">{{ entry.cmc }}</td>
                            <td class="text-right">{{ entry.legal }}</td>
                        {% endif %}
                    </tr>
                {% endfor %}
            {% endmacro %}

            <!-- MACRO : TOTAL -->
            {% macro render_total(total, title, tr_style = '', all_cells_style = '', value_cells_style = '') %}
                <tr style="{{ tr_style }}">
                    {% if is_set_1 %}
                        <td colspan="8" class="bold" style="border-top: 0; border-bottom: 0; {{ all_cells_style }}">
                            {{ title }}
                        </td>

                        <td class="text-right bold" style="border-top: 1px solid #111827; border-bottom: 0; {{ all_cells_style }} {{ value_cells_style }}">
                            {{ total.total_amort }}
                        </td>

                        <td class="text-right bold" style="border-top: 1px solid #111827; border-bottom: 0; {{ all_cells_style }} {{ value_cells_style }}">
                            {{ total.total_current }}
                        </td>

                        <td class="text-right bold" style="border-top: 1px solid #111827; border-bottom: 0; {{ all_cells_style }} {{ value_cells_style }}">
                            {{ total.total_restuct }}
                        </td>

                        <td class="text-right bold" style="border-top: 1px solid #111827; border-bottom: 0; {{ all_cells_style }} {{ value_cells_style }}">
                            {{ total.total_renewal }}
                        </td>
                    {% endif %}

                    {% if is_set_2 %}
                        <td colspan="9" class="bold" style="border-top: 0; border-bottom: 0; {{ all_cells_style }}">
                            {{ title }}
                        </td>

                        <td class="text-right bold" style="border-top: 1px solid #111827; border-bottom: 0; {{ all_cells_style }} {{ value_cells_style }}">
                            {{ total.total_amort }}
                        </td>

                        <td class="text-right bold" style="border-top: 1px solid #111827; border-bottom: 0; {{ all_cells_style }} {{ value_cells_style }}">
                            {{ total.total_current }}
                        </td>

                        <td class="text-right bold" style="border-top: 1px solid #111827; border-bottom: 0; {{ all_cells_style }} {{ value_cells_style }}">
                            {{ total.total_restuct }}
                        </td>

                        <td class="text-right bold" style="border-top: 1px solid #111827; border-bottom: 0; {{ all_cells_style }} {{ value_cells_style }}">
                            {{ total.total_renewal }}
                        </td>
                    {% endif %}

                    {% if is_set_3 %}
                        <td colspan="6" class="bold" style="border-top: 0; border-bottom: 0; {{ all_cells_style }}">
                            {{ title }}
                        </td>

                        <td class="text-right bold" style="border-top: 1px solid #111827; border-bottom: 0; {{ all_cells_style }} {{ value_cells_style }}">
                            {{ total.total_amount_applied }}
                        </td>

                        <td class="text-right bold" style="border-top: 1px solid #111827; border-bottom: 0; {{ all_cells_style }} {{ value_cells_style }}">
                            {{ total.total_interest_on_loan }}
                        </td>

                        <td class="text-right bold" style="border-top: 1px solid #111827; border-bottom: 0; {{ all_cells_style }} {{ value_cells_style }}">
                            {{ total.total_amount_granted }}
                        </td>
                    {% endif %}

                    {% if is_set_4 %}
                        <td colspan="5" class="bold" style="border-top: 0; border-bottom: 0; {{ all_cells_style }}">
                            {{ title }}
                        </td>

                        <td class="text-right bold" style="border-top: 1px solid #111827; border-bottom: 0; {{ all_cells_style }} {{ value_cells_style }}">
                            {{ total.total_amort }}
                        </td>

                        <td class="text-right bold" style="border-top: 1px solid #111827; border-bottom: 0; {{ all_cells_style }} {{ value_cells_style }}">
                            {{ total.total_amount_granted }}
                        </td>

                        <td colspan="7" style="border-top: 0; border-bottom: 0; {{ all_cells_style }}"></td>
                    {% endif %}
                </tr>
            {% endmacro %}

            <!-- MACRO : RECURSIVE GROUP -->
            {% macro render_group(groups) %}
                {% for group in groups %}
                    <tr>
                        <td
                            colspan="
                                {% if is_set_1 %}12{% endif %}
                                {% if is_set_2 %}13{% endif %}
                                {% if is_set_3 %}9{% endif %}
                                {% if is_set_4 %}14{% endif %}
                            "
                            class="bold"
                        >
                            {{ group.group_name }} : {{ group.roup_title }}
                        </td>
                    </tr>

                    {% if group.sub_groups and group.sub_groups.length %}
                        {{ render_group(group.sub_groups) }}
                    {% endif %}

                    {% if group.data_entries and group.data_entries.length %}
                        {{ render_data_entries(group.data_entries) }}
                    {% endif %}

                    {{ render_total(group.total_per, group.group_name + ' TOTAL') }}

                    {% if not loop.last %}
                        <tr>
                            <td
                                colspan="
                                    {% if is_set_1 %}12{% endif %}
                                    {% if is_set_2 %}13{% endif %}
                                    {% if is_set_3 %}9{% endif %}
                                    {% if is_set_4 %}14{% endif %}
                                "
                                style="border: 0; padding: 10px;"
                            ></td>
                        </tr>
                    {% endif %}
                {% endfor %}
            {% endmacro %}

            <!-- MAIN TABLE -->
            <table class="table">
                {{ render_table_head() }}

                <tbody>
                    {% if grouping == 'no_grouping' %}
                        {{ render_data_entries(no_grouping_data_entries) }}
                    {% else %}
                        {{ render_group(grouped_data) }}
                    {% endif %}

                    <tr>
                        <td
                            colspan="
                                {% if is_set_1 %}12{% endif %}
                                {% if is_set_2 %}13{% endif %}
                                {% if is_set_3 %}9{% endif %}
                                {% if is_set_4 %}14{% endif %}
                            "
                            style="border: 0; padding: 10px 0;"
                        ><br></td>
                    </tr>

                    <tr>
                        <td
                            colspan="
                                {% if is_set_1 %}12{% endif %}
                                {% if is_set_2 %}13{% endif %}
                                {% if is_set_3 %}9{% endif %}
                                {% if is_set_4 %}14{% endif %}
                            "
                            style="border: 0; padding: 0; border-top: 1px solid #111827;"
                        ></td>
                    </tr>

                    <!-- GRAND TOTAL -->
                    {{ render_total(
                        grand_total,
                        'GRAND TOTAL',
                        'border: 0',
                        'border: 0'
                    ) }}
                </tbody>
            </table>
        </div>
    </body>
</html>
